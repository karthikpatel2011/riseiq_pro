# Copy this file to .env and fill in your actual values

# Groq API key — https://console.groq.com/keys
VITE_GROQ_API_KEY=your_groq_api_key_here

# Firebase (Auth + Firestore only) — https://console.firebase.google.com > Project Settings > Your apps > Config
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudinary (file uploads — photos, PDFs, project files)
# 1. Sign up free at https://cloudinary.com
# 2. Your Cloud Name is on the dashboard homepage
# 3. Go to Settings → Upload → Add upload preset → set Signing Mode to "Unsigned"
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
